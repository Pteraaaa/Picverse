generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id Int @id @default(autoincrement())

  name String

  email String @unique

  password String

  profilePicture String?

  artworks Artwork[]

  createdAt    DateTime       @default(now())
  artworkLikes ArtworkLikes[]
  submissions  Submission[]
}

model Artwork {
  id Int @id @default(autoincrement())

  title String

  description String

  imageUrl String

  likes Int @default(0)

  userId Int

  user User @relation(fields: [userId], references: [id])

  tags Tag[]

  createdAt DateTime @default(now())

  artworkLikes ArtworkLikes[]
}

model ArtworkLikes {
  userId Int

  artworkId Int

  user User? @relation(fields: [userId], references: [id])

  artwork Artwork? @relation(fields: [artworkId], references: [id])

  @@id([userId, artworkId])
}

model Tag {
  id Int @id @default(autoincrement())

  name String @unique

  artworks Artwork[]
}

model Submission {
  id            Int      @id @default(autoincrement())
  email         String
  title         String
  description   String
  fileUrl       String
  fileName      String
  isAiGenerated Boolean
  tags          String
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


